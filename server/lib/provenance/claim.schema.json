{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "claim_id",
    "text",
    "extraction_step_id",
    "provenance_kind",
    "parent_claim_ids",
    "root_sources",
    "ingest_id"
  ],
  "properties": {
    "claim_id": { "type": "string", "minLength": 1 },
    "text": { "type": "string", "minLength": 1 },
    "source_span_id": {
      "type": ["object", "null"],
      "properties": {
        "source_hash": { "type": "string" },
        "span_id": { "type": "string" },
        "chunk_index": { "type": "integer" },
        "char_start": { "type": "integer" },
        "char_end": { "type": "integer" }
      }
    },
    "extraction_step_id": { "type": "string" },
    "confidence": { "type": ["number", "null"] },
    "provenance_kind": {
      "enum": ["llm-tier-a", "llm-tier-b", "llm-tier-c", "heuristic", "human-edited", "derived"]
    },
    "parent_claim_ids": { "type": "array", "items": { "type": "string" } },
    "root_sources": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "ingest_id": { "type": "string" },
    "derived_from": { "type": ["array", "null"], "items": { "type": "string" } },
    "verified_by": { "type": ["string", "null"] }
  },
  "allOf": [
    {
      "if": { "properties": { "provenance_kind": { "const": "heuristic" } } },
      "then": { "properties": { "confidence": { "type": "null" } } }
    },
    {
      "if": { "properties": { "provenance_kind": { "const": "human-edited" } } },
      "then": {
        "required": ["verified_by"],
        "properties": { "confidence": { "type": "null" } }
      }
    },
    {
      "if": { "properties": { "provenance_kind": { "const": "derived" } } },
      "then": {
        "required": ["derived_from"],
        "properties": { "derived_from": { "type": "array", "minItems": 1 } }
      }
    },
    {
      "if": {
        "properties": {
          "provenance_kind": { "enum": ["llm-tier-a", "llm-tier-b", "llm-tier-c"] }
        }
      },
      "then": {
        "properties": {
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
        },
        "required": ["confidence", "source_span_id"]
      }
    }
  ]
}
