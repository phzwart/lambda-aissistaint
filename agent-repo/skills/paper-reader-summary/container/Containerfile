FROM docker.io/library/python:3.11-slim

ENV PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PQA_HOME=/workspace/.pqa \
    HOME=/workspace \
    TORCH_HOME=/workspace/.torch \
    QT_QPA_PLATFORM=offscreen \
    MPLBACKEND=Agg \
    OPENCV_OPENCL_RUNTIME=disabled \
    TORCH_FORCE_NO_WEIGHTS_ONLY_LOAD=1

# Headless runtime libraries for layoutparser / OpenCV / Paddle (PubLayNet).
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        ca-certificates \
        curl \
        libglib2.0-0 \
        libsm6 \
        libxext6 \
        libxrender1 \
        libx11-6 \
        libxcb1 \
        libgl1 \
        libgomp1 \
    && rm -rf /var/lib/apt/lists/*

RUN groupadd --system runner \
    && useradd --system --gid runner --home-dir /workspace --create-home runner

WORKDIR /workspace

COPY cli /tmp/paper-reader-summary-cli
COPY container/prefetch_layout_model.py /tmp/prefetch_layout_model.py

RUN python -m pip install --upgrade pip \
    && python -m pip install "/tmp/paper-reader-summary-cli[layout]" \
    && rm -rf /tmp/paper-reader-summary-cli

# Pre-download Paddle PubLayNet weights under /workspace (readable by runner user).
RUN mkdir -p /workspace/.torch/iopath_cache \
    && curl -fsSL --retry 5 --retry-delay 3 \
        -o /workspace/.torch/iopath_cache/ppyolov2_r50vd_dcn_365e_publaynet.tar \
        "https://paddle-model-ecology.bj.bcebos.com/model/layout-parser/ppyolov2_r50vd_dcn_365e_publaynet.tar" \
    && python -c "import os; p='/workspace/.torch/iopath_cache/ppyolov2_r50vd_dcn_365e_publaynet.tar'; assert os.path.getsize(p) > 100_000_000, os.path.getsize(p)"

# Warm up layout model (fails the image build if layout stack is broken).
RUN python /tmp/prefetch_layout_model.py \
    && rm -f /tmp/prefetch_layout_model.py

RUN mkdir -p /workspace/input /workspace/output /workspace/.pqa \
    && chown -R runner:runner /workspace

USER runner

ENTRYPOINT ["paper-reader-summary"]
