# Frontend runtime flags and visible app labels.
VITE_USE_MOCK_SERVICES=true
VITE_APP_TITLE=AIssistAInt
VITE_APP_SUBTITLE=Knowledge & Question Processor
VITE_PREFERENCES_SUBTITLE=Configure LiteLLM provider models, agent behavior, and secure workflow settings.
VITE_LLM_TIERS=A,B,C

# Browser-facing authentication and API endpoints.
VITE_KEYCLOAK_URL=https://keycloak.aissistaint.localhost:8443
VITE_KEYCLOAK_REALM=minio
VITE_KEYCLOAK_CLIENT_ID=aissistaint-ui
VITE_API_BASE_URL=
VITE_OPENBAO_URL=https://openbao.aissistaint.localhost:8443
CORS_ALLOWED_ORIGINS=https://aissistaint.localhost:8443,http://localhost:5173,http://127.0.0.1:5173
LLM_ALLOWED_HOSTS=api.cborg.lbl.gov
LLM_ALLOW_PRIVATE_ENDPOINTS=false
LLM_ALLOW_HTTP_ENDPOINTS=false
LLM_ALLOW_ANY_HOSTS=false
LLM_DEV_MODE=false
LLM_REQUEST_TIMEOUT_MS=30000

# Stack path defaults shared by Podman scripts and host-run Node processes.
# Leave BASE_DIR blank to use ~/$STACK_NAME.
STACK_NAME=platform-demo
BASE_DIR=

# Service ownership switches. Set a value to 0 when using an external replacement.
MANAGE_TLS_GATEWAY=1
MANAGE_KEYCLOAK_POSTGRES=1
MANAGE_KEYCLOAK=1
MANAGE_APP_POSTGRES=1
MANAGE_OPENBAO=1
MANAGE_MINIO=1
MANAGE_LITELLM=1
MANAGE_GOOSE=1

# Local TLS gateway and raw-port exposure settings.
TLS_GATEWAY_ENABLED=1
TLS_GATEWAY_PORT=8443
TLS_HTTP_PORT=8088
EXPOSE_RAW_SERVICE_PORTS=1
API_HOST=127.0.0.1
GATEWAY_BIND_HOST=127.0.0.1

# Public HTTPS URLs advertised to browsers and OIDC clients.
PUBLIC_APP_URL=https://aissistaint.localhost:8443
PUBLIC_KEYCLOAK_URL=https://keycloak.aissistaint.localhost:8443
PUBLIC_OPENBAO_URL=https://openbao.aissistaint.localhost:8443
PUBLIC_MINIO_URL=https://minio.aissistaint.localhost:8443
PUBLIC_MINIO_CONSOLE_URL=https://minio-console.aissistaint.localhost:8443

# Backend/internal URLs used by scripts and server-side service clients.
INTERNAL_KEYCLOAK_URL=http://127.0.0.1:8080
INTERNAL_OPENBAO_URL=http://127.0.0.1:8200
INTERNAL_MINIO_ENDPOINT=http://127.0.0.1:9000
INTERNAL_LITELLM_URL=http://127.0.0.1:4000
INTERNAL_GOOSE_URL=http://127.0.0.1:3284

# Reverse-proxy upstreams. Point these at external services when swapped.
GATEWAY_KEYCLOAK_UPSTREAM=http://platform-demo-keycloak:8080
GATEWAY_OPENBAO_UPSTREAM=http://platform-demo-openbao:8200
GATEWAY_MINIO_UPSTREAM=http://platform-demo-minio:9000
GATEWAY_MINIO_CONSOLE_UPSTREAM=http://platform-demo-minio:9001

# Application database and scoped MinIO credentials live in API_SECRET_ENV_FILE.
# Removal credentials live in API_REMOVAL_ENV_FILE when enabled.
MINIO_ENDPOINT=https://minio.aissistaint.localhost:8443
PROJECT_BUCKET_PREFIX=aissistaint-project
PROJECT_LOADED_PREFIX=loaded
PROJECT_PARSED_PREFIX=parsed
# When true, ingest traces store prompt/response bodies; when false, hashes only.
INGEST_TRACE_RETAIN_CONTENT=false
PROJECT_METADATA_OBJECT_KEY=project.json
MINIO_REMOVAL_POLICY_NAME=project-removal-rw

# Persistent wiki layer. Pages live as Markdown inside the existing per-project
# MinIO bucket under WIKI_BUCKET_PREFIX, with rebuildable JSON sidecars under
# WIKI_METADATA_PREFIX. Set WIKI_LLM_TIER to which configured LiteLLM alias
# (a/b/c) is used for synthesis and grounded query. If the tier is unavailable
# the wiki layer falls back to a deterministic heuristic extractor.
WIKI_BUCKET_PREFIX=wiki
WIKI_METADATA_PREFIX=metadata
WIKI_LLM_TIER=a
WIKI_MAX_CHUNKS_PER_INGEST=12
WIKI_MAX_PAGE_BYTES=131072

# Agent repository loading. Leave blank to load ./agent-repo when present.
# Use comma-separated absolute or repo-relative paths to load multiple repositories.
AGENT_REPO_DIRECTORIES=
PLANNER_REPO_DIRECTORIES=
PAPERQA2_RUNNER_IMAGE=localhost/aissistaint/paperqa2-paper-reader:latest
PAPERQA_LITELLM_URL=http://127.0.0.1:4000
# Defaults to LITELLM_API_KEY from platform runtime env when unset.
# PAPERQA_LITELLM_API_KEY=
PAPERQA_DEFAULT_EMBEDDING_MODEL=st-multi-qa-MiniLM-L6-cos-v1
PAPERQA_LLM_TIER=a
PAPERQA_PROCESS_INGEST_WIKI=true
PAPERQA_PODMAN_NETWORK=host
# Wall-clock cap for one PDF job (ms). Omit to use max(45 min, 5 × PAPERQA_LITELLM_TIMEOUT_S).
# PAPERQA_RUNNER_TIMEOUT_MS=2700000
# Per LiteLLM completion call inside PaperQA (seconds). Upstream proxy must allow at least this long.
# CBorg/Cloudflare often enforces ~120s unless the proxy timeout is raised (HTTP 524).
PAPERQA_LITELLM_TIMEOUT_S=900
# PaperQA per-chunk evidence: false avoids JSON score parsing failures on chatty models.
# PAPERQA_USE_JSON_CONTEXT=false
# Skip LLM summarization of each excerpt (recommended for our long structured-summary query).
# PAPERQA_EVIDENCE_SKIP_SUMMARY=true
# Multimodal paper preprocessing (paper-reader-summary container)
# PAPER_RENDER_DPI=300
# PAPER_LAYOUT_ENABLED=true
# PAPER_LAYOUT_MODEL=lp://PubLayNet/ppyolov2_r50vd_dcn_365e/config
# PAPER_LAYOUT_THRESHOLD=0.35
# PAPER_LAYOUT_TARGET_SIZE=640,640
# PAPER_MULTIMODAL_DEBUG=false
# PAPER_EQUATION_OCR=false
# Per-project extended-abstract and follow-up-question instructions: Setup → Agent → Paper Reader Summary (project enablement).
# Upload parsed/ artifacts to MinIO while the runner is still working (default 10s).
# PROJECT_PROCESS_ARTIFACT_SYNC_MS=10000

# LiteLLM proxy. Provider API keys should not be stored in repo env files;
# use the Preferences UI to write/rotate encrypted records into the secret store.
LITELLM_PORT=4000
LITELLM_ADMIN_BROKER_URL=http://127.0.0.1:8788

# Headless Goose chatbot. The API prefers managed Goose when enabled and falls
# back to direct LiteLLM tier routing without exposing provider keys or raw
# prompt bodies in audit logs.
GOOSE_PORT=3284
GOOSE_IMAGE=ghcr.io/aaif-goose/goose:latest
GOOSE_PROVIDER=openai
GOOSE_MODEL=LLM_A
GOOSE_WORKING_DIR=/workspace
# Host path for generated planner skill stubs; blank uses ${BASE_DIR:-~/$STACK_NAME}/goose/workspace.
GOOSE_WORKSPACE_DIR=
GOOSE_SECRET_ENV_FILE=
GOOSE_CHATBOT_BACKEND=goose
GOOSE_CHATBOT_DEFAULT_TIER=A
GOOSE_CHATBOT_MAX_MESSAGES=24
GOOSE_CHATBOT_MAX_TOKENS=768
GOOSE_CHATBOT_TEMPERATURE=0.2
GOOSE_CHATBOT_SYSTEM_PROMPT=You are Goose, a concise AI assistant embedded in AIssistAInt. Answer helpfully, avoid exposing secrets, and ask for missing project context when needed.

# Split runtime secret files generated by podman_services/podman_infra_bootstrap.sh.
# Keep these files 0600 and out of git; the stack runtime env should contain
# file pointers and routing config, not high-sensitivity secret values.
API_SECRET_ENV_FILE=
API_REMOVAL_ENV_FILE=
API_LOAD_REMOVAL_SECRETS=false
LITELLM_ADMIN_BROKER_ENV_FILE=
LITELLM_SECRET_BROKER_ENV_FILE=

# Generic secret-store and encryption settings. OpenBao is the current adapter;
# AWS/GCP adapters can use the same encrypted payload shape later.
SECRET_STORE_PROVIDER=openbao
SECRET_ENCRYPTION_KEY_FILE=
SECRET_ENCRYPTION_KEY_VERSION=v1

# Backend proxy process and generated platform environment file.
API_PORT=8787
# Leave blank to use ${BASE_DIR:-~/$STACK_NAME}/$STACK_NAME-runtime.env.
PLATFORM_ENV_FILE=
