{
  "name": "aissistaint-ui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:api\" \"npm:dev:litellm-admin\" \"npm:dev:ui\"",
    "dev:ui": "vite --host 0.0.0.0",
    "dev:api": "node server/index.mjs",
    "dev:litellm-admin": "node server/litellm-admin-broker.mjs",
    "test": "node --test",
    "build": "tsc -b && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1038.0",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "jose": "^6.2.3",
    "keycloak-js": "latest",
    "pg": "^8.20.0",
    "react": "18",
    "react-dom": "18",
    "react-router-dom": "6",
    "zustand": "latest"
  },
  "devDependencies": {
    "@types/react": "18",
    "@types/react-dom": "18",
    "@vitejs/plugin-react": "latest",
    "typescript": "latest",
    "vite": "latest"
  }
}
